<%- include('../header') %>

<div class="page-wrapper">
<div class="container mt-5">
    <div class="card shadow-lg border-0 rounded-4 p-4">

        <img src="/uploads/<%= blog.image %>" 
             class="img-fluid rounded-4 mb-4"
             style="max-height:400px; object-fit:cover; width:100%;">

        <h2 class="fw-bold mb-3"><%= blog.title %></h2>

        <div class="row mb-3">
            <div class="col-md-6">
                <p><strong>Author:</strong> <%= blog.author %></p>
            </div>
            <div class="col-md-6">
                <p><strong>Category:</strong> <%= blog.category %></p>
            </div>
        </div>

        <p class="text-muted"><%= blog.shortDesc %></p>

        <hr>

        <p><%= blog.fullDesc %></p>

        <div class="d-flex gap-3 mt-4">
            <a href="/blog/edit/<%= blog._id %>" 
               class="btn btn-warning px-4 rounded-3 fw-bold">
                ✏ Edit
            </a>
            &nbsp;
            <a href="/blog/delete/<%= blog._id %>" 
               class="btn btn-danger px-4 rounded-3 fw-bold">
                🗑 Delete
            </a>
            &nbsp
            <a href="/blog/view-blog" 
               class="btn btn-success px-4 rounded-3 fw-bold">
                Back
            </a>
        </div>

    </div>
</div>
</div>

<%- include('../footer') %>