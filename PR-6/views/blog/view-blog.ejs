<%- include('../header') %>

<!-- Page Wrapper -->
<div class="page-wrapper">
    <div class="container-fluid mt-4">

        <div class="row">
            <% blogs.forEach(blog => { %>
                <div class="col-md-4 mb-4">
                    <div class="card shadow">
                        <img src="/uploads/<%= blog.image %>" class="card-img-top" height="200">

                        <div class="card-body">
                            <h5><%= blog.title %></h5>
                            <p><%= blog.shortDesc %></p>

                            <a href="/blog/view/<%= blog._id %>" class="btn btn-primary">
                                View
                            </a>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>

    </div>
</div>
<!-- End Page Wrapper -->

<%- include('../footer') %>