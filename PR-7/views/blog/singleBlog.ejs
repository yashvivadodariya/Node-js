<%- include('../header') %>

    <style>
        .category-top-badge {
            position: absolute;
            top: 20px;
            left: 20px;
            font-size: 16px;
            padding: 8px 18px;
            border-radius: 30px;
            background: #4e73df;
            color: white;
            font-weight: 600;
        }

        .blog-detail-card {
            position: relative;
            border-radius: 18px;
            backdrop-filter: blur(10px);
            background: rgba(255, 255, 255, 0.9);
        }

        .blog-detail-img {
            width: 100%;
            height: 420px;
            object-fit: cover;
        }

        .desc-box {
            background: #f8f9ff;
            border-left: 5px solid #4e73df;
            padding: 18px;
            border-radius: 10px;
        }

        .content-box {
            background: #ffffff;
        }

        .blog-content {
            line-height: 1.9;
            font-size: 16px;
            text-align: justify;
            color: #444;
        }

        .blog-detail-card:hover {
            transform: translateY(-3px);
            transition: 0.3s ease;
        }
    </style>



    <div class="page-wrapper" style="background: #e1e8f9; min-height: 100vh;">
        <div class="container-fluid py-4">

            <div class="mb-4">
                <a href="/Blog/view-blog" class="btn btn-outline-secondary rounded-pill px-4">
                    ← Back to Blogs
                </a>
            </div>

            <div class="row justify-content-center">
                <div class="col-lg-10">

                    <div class="card blog-detail-card shadow-lg border-0">

                        <img src="<%= blog.blogImg %>" class="blog-detail-img" alt="blog image">

                        <div class="card-body p-4 p-md-5">

                            <span class="category-top-badge">
                                <%= blog.category || 'General' %>
                            </span>

                            <h1 class="mb-3 font-weight-bold">
                                <%= blog.title %>
                            </h1>

                            <p class="text-muted mb-4">
                                <strong>Author:</strong>
                                <%= blog.author %>
                                    &nbsp; | &nbsp;
                                    <strong>Date:</strong>
                                    <%= blog.publishDate %>
                            </p>

                            <hr class="my-4">

                            <div class="desc-box mb-4">
                                <h5 class="mb-2">Short Description</h5>
                                <p class="mb-0">
                                    <%= blog.description %>
                                </p>
                            </div>

                            <div class="content-box">
                                <h4 class="mb-3">Full Blog Content</h4>
                                <p class="blog-content">
                                    <%= blog.content %>
                                </p>
                            </div>

                            <div class="mt-5 d-flex gap-3">
                                <a href="/blog/edit-blog/<%= blog._id %>"
                                    class="btn btn-warning px-4 mr-5 rounded-pill">
                                    ✏ Edit
                                </a>
                                <a href="/blog/delete-blog/<%= blog._id %>" class="btn btn-danger px-4 rounded-pill">
                                    🗑 Delete
                                </a>
                            </div>

                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>

    <%- include('../footer') %>