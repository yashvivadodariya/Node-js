<%- include('../header') %>
    <style>
        .blog-title-box {
            background-color: #ebf0fc;
            border-left: 5px solid #4e73df;
            padding: 12px 18px;
            border-radius: 6px;
        }

        .blog-card {
            border-radius: 18px;
            overflow: hidden;
            border: none;
            background: #ffffff;
            transition: 0.3s ease;
        }

        .small-category-badge {
            display: inline-block;
            font-size: 11px;
            padding: 4px 10px;
            background: #4e73df;
            color: #fff;
            border-radius: 20px;
            font-weight: 500;
            margin: 10px 0 5px 15px;
            width: fit-content;
        }

        .search-box {
            border-radius: 12px;
            margin-bottom: 15px;
        }

        .search-box .btn-outline-primary {
            font-size: 12px;
            padding: 5px 14px;
            transition: 0.3s ease;
        }

        .search-box .btn-outline-primary:hover {
            background-color: #4e73df;
            color: #fff;
            border-color: #4e73df;
        }

        .rounded-pill {
            border-radius: 12px;
            margin: 0px 6px;
        }
    </style>


    <div class="page-wrapper" style="background-color: #c9d7f7;">
        <div class="page-breadcrumb">
            <div class="row align-items-center">
                <div class="col-12 d-flex no-block align-items-center mb-3">
                    <h4 class="page-title">Blog List</h4>
                    <div class="ml-auto text-right">
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb">
                                <li class="breadcrumb-item"><a href="#">Home</a></li>
                                <li class="breadcrumb-item active">Library</li>
                            </ol>
                        </nav>
                    </div>
                </div>

                <div class="col-12">
                    <div class="search-box p-3 bg-white rounded shadow-sm">

                        <form method="GET" action="/Blog/view-blog">
                            <div class="row">
                                <div class="col-md-10">
                                    <input type="text" name="search" class="form-control"
                                        placeholder="Search by title or category (e.g. AI, Technology, Business)"
                                        value="<%= search || '' %>">
                                </div>

                                <div class="col-md-2">
                                    <button type="submit" class="btn btn-primary w-100">
                                        🔍 Search
                                    </button>
                                </div>
                            </div>
                        </form>

                        <div class="mt-3 d-flex flex-wrap gap-2">
                            <a href="/Blog/view-blog" class="btn btn-sm btn-outline-dark rounded-pill">
                                All
                            </a>

                            <a href="/Blog/view-blog?search=Technology"
                                class="btn btn-sm btn-outline-primary rounded-pill">
                                Technology
                            </a>

                            <a href="/Blog/view-blog?search=Business"
                                class="btn btn-sm btn-outline-primary rounded-pill">
                                Business & Finance
                            </a>

                            <a href="/Blog/view-blog?search=Education"
                                class="btn btn-sm btn-outline-primary rounded-pill">
                                Education
                            </a>

                            <a href="/Blog/view-blog?search=Lifestyle"
                                class="btn btn-sm btn-outline-primary rounded-pill">
                                Lifestyle
                            </a>

                            <a href="/Blog/view-blog?search=Entertainment"
                                class="btn btn-sm btn-outline-primary rounded-pill">
                                Entertainment
                            </a>

                            <a href="/Blog/view-blog?search=AI" class="btn btn-sm btn-outline-primary rounded-pill">
                                AI
                            </a>
                            <a href="/Blog/view-blog?search=Food" class="btn btn-sm btn-outline-primary rounded-pill">
                                Food
                            </a>
                            <a href="/Blog/view-blog?search=Fitness" class="btn btn-sm btn-outline-primary rounded-pill">
                                Fitness
                            </a>
                        </div>

                    </div>
                </div>

            </div>
        </div>
        <div class="col-12">
            <div class="card">
                <div class="card-body blog-title-box">
                    <h5 class="card-title m-b-3">Blogs</h5>

                    <div class="row">
                        <% blogs.forEach((blog, i)=>{ %>
                            <div class="col-md-4 mb-4">
                                <div class="card blog-card shadow-sm h-100">

                                    <img src="<%= blog.blogImg %>" class="card-img-top" height="220"
                                        style="object-fit: cover;" alt="img">

                                    <span class="small-category-badge">
                                        <%= blog.category %>
                                    </span>

                                    <div class="card-body">
                                        <h5 class="card-title">
                                            <%= blog.title %>
                                        </h5>

                                        <p class="card-text text-muted mb-1">
                                            <%= blog.author %> | <%= blog.publishDate %>
                                        </p>

                                        <p class="card-text">
                                            <%= blog.description %>
                                        </p>

                                        <a href="/Blog/view-single/<%= blog._id %>"
                                            class="btn btn-outline-primary btn-sm">
                                            View More →
                                        </a>
                                    </div>

                                </div>
                            </div>
                            <% }) %>
                    </div>

                </div>
            </div>
        </div>

    </div>
    <%- include('../footer')%>