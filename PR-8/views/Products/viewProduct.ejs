<%- include('../header') %>

<style>
    .product-card {
        border: none;
        border-radius: 15px;
        overflow: hidden;
        transition: 0.3s;
        background: #fff;
    }

    .product-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 10px 25px rgba(0,0,0,0.15);
    }

    .product-img {
        height: 200px;
        object-fit: cover;
    }

    .product-title {
        font-size: 18px;
        font-weight: 600;
    }

    .product-desc {
        font-size: 14px;
        color: #777;
        height: 40px;
        overflow: hidden;
    }

    .price {
        font-size: 18px;
        font-weight: bold;
        color: #28a745;
    }

  .badge-custom {
    font-size: 11px;
    padding: 5px 8px;
    margin: 2px;
    border-radius: 6px;
    color: #fff !important; 
}

    .btn-custom {
        border-radius: 20px;
        font-size: 13px;
        padding: 5px 12px;
    }
</style>

<div class="page-wrapper">
    <div class="container-fluid">
        <div class="row">

            <% products.forEach((prod)=>{ %>
                <div class="col-md-3 mb-4">

                    <div class="card product-card">

                        <% if (prod.prodImg) { %>
                            <img src="<%= prod.prodImg %>" class="card-img-top product-img">
                        <% } else { %>
                            <img src="https://via.placeholder.com/200" class="card-img-top product-img">
                        <% } %>

                        <div class="card-body">

                            <h5 class="product-title"><%= prod.prodName %></h5>

                            <p class="product-desc"><%= prod.prodDes %></p>

                            <div class="price mb-2">
                                ₹ <%= prod.prodPrice %>
                            </div>

                            <!-- Category badges -->
                            <div>
                                <span class="badge bg-primary badge-custom">
                                    <%= prod.categoryId ? prod.categoryId.categoryName : "No Category" %>
                                </span>

                                <span class="badge bg-info badge-custom">
                                    <%= prod.subCategoryId ? prod.subCategoryId.subCategoryName : "No Sub" %>
                                </span>

                                <span class="badge bg-dark badge-custom">
                                    <%= prod.extracategoryId ? prod.extracategoryId.extraCategoryName : "No Extra" %>
                                </span>
                            </div>

                            <div class="mt-3 d-flex justify-content-between">
                                <a href="/products/edit-product/<%= prod._id %>" 
                                   class="btn btn-warning btn-sm btn-custom">
                                   ✏ Edit
                                </a>

                                <a href="/products/delete-product/<%= prod._id %>" 
                                   class="btn btn-danger btn-sm btn-custom">
                                   🗑 Delete
                                </a>
                            </div>

                        </div>
                    </div>

                </div>
            <% }) %>

        </div>
    </div>
</div>

<%- include('../footer') %>